<script>
  // VULN (S-DOM-CLOB-001 / Ch 37): "promo bar" looks up a runtime
  // config variable on the window object and uses it as a URL.  If
  // any stored HTML on the page introduces a top-level element with
  // id="PROMO_LINK", that element shadows the JS global and clicking

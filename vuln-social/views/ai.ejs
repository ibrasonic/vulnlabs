<%- include('partials/header') %>
<h1>PulseMod &mdash; AI summary</h1>
<p class="muted">Generate a moderation-ready summary of any post on the network.</p>
<% if (msg) { %><div class="ok"><%= msg %></div><% } %>
<form method="post" action="/ai-summary/summarize">
  <label>Post ID <input name="post_id" value="<%= postId %>"></label>
  <label>Moderator context <input name="extra_context" placeholder="optional"></label>
  <label>Mode
    <select name="mode">
      <option value="summary">summary (default)</option>
      <option value="agent">agent (with web_fetch tool)</option>
    </select>
  </label>
  <button>Summarize</button>
</form>

<h2>Knowledge-base search (RAG)</h2>
<p class="muted">Query the internal help desk &mdash; retrieves docs and recent community posts to answer.</p>
<form method="post" action="/ai-summary/search">
  <label>Question <input name="q" value="<%= searchQuery || '' %>" placeholder="how do I appeal a takedown?"></label>
  <button>Ask</button>
</form>

<% if (summary) { %>
  <h2>Summary</h2>
  <pre class="ai"><%= summary %></pre>
  <%# VULN (V-SOC-087, LLM05 Improper Output Handling): the model output is
      rendered as HTML so moderators get formatted cards. The text is never
      sanitised, so a prompt-injection payload that makes the model emit HTML
      (e.g. <img src=x onerror=...>) executes in the moderator's browser. The
      same text was written to ai_logs above, so this is STORED XSS: it also
      fires in the "Recent activity" table below for every later viewer. %>
  <h3>Rendered card (moderator preview)</h3>
  <div class="ai-card"><%- summary %></div>
<% } %>
<% if (agentTrace) { %>
  <h2>Agent trace</h2>
  <ol>
    <% agentTrace.forEach(function(s){ %>
      <li><strong>step <%= s.step %></strong> [<%= s.provider %>]: <pre class="ai"><%= s.text %></pre></li>
    <% }) %>
  </ol>
<% } %>
<% if (searchHits) { %>
  <h2>Retrieved snippets</h2>
  <table class="grid">
    <thead><tr><th>#</th><th>Kind</th><th>ID</th><th>Title</th><th>Visibility</th><th>Score</th><th>Body (truncated)</th></tr></thead>
    <tbody>
      <% searchHits.forEach(function(h, i){ %>
        <tr>
          <td><%= i + 1 %></td>
          <td><%= h.kind %></td>
          <td><%= h.id %></td>
          <td><%= h.title %></td>
          <td><%= h.visibility %></td>
          <td><%= h.score %></td>
          <td><code><%= (h.body || '').slice(0, 160) %></code></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>
<h2>Recent activity</h2>
<table class="grid">
  <thead><tr><th>ID</th><th>User</th><th>Prompt</th><th>Response</th><th>Rendered card</th></tr></thead>
  <tbody>
    <% recent.forEach(a => { %>
      <tr>
        <td><%= a.id %></td>
        <td><%= a.username || 'system' %></td>
        <td><code><%= (a.prompt || '').slice(0, 120) %></code></td>
        <td><code><%= (a.response || '').slice(0, 200) %></code></td>
        <%# VULN (V-SOC-087): stored-XSS sink. Every stored AI response is
            re-rendered here as HTML with no escaping, so a payload planted
            once fires in the browser of every moderator who loads this page. %>
        <td class="ai-card"><%- a.response %></td>
      </tr>
    <% }) %>
  </tbody>
</table>
<%- include('partials/footer') %>

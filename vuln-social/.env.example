# Copy this file to ".env" (same folder) and fill in your real key.
# docker compose automatically loads .env from the compose project folder,
# so both `docker compose up` and `run.ps1` will pick this up.

# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional. Defaults to gemini-2.0-flash. Examples: gemini-2.0-flash, gemini-1.5-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-2.0-flash

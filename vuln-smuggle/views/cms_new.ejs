<%- include('partials/header', { title: 'New draft - CMS' }) %>
<section class="cms">
  <h1>New draft</h1>
  <form method="post" action="/cms/article/new" class="cms-form">
    <label>Slug <input name="slug" required pattern="[a-z0-9-]+"></label>
    <label>Title <input name="title" required></label>
    <label>Deck <input name="deck"></label>
    <label>Category
      <select name="category">
        <option>politics</option><option>business</option><option>tech</option>
        <option>sport</option><option>culture</option><option selected>opinion</option>
      </select>
    </label>
    <label><input type="checkbox" name="paywall" value="1"> Subscribers only</label>
    <label>Body (HTML)
      <textarea name="body" rows="14" required></textarea>
    </label>
    <button class="btn primary">Save as draft</button>
  </form>
</section>
<%- include('partials/footer') %>

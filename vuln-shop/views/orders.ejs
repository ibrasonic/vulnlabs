<%- include('partials/header') %>
<h1>Your orders</h1>
<% if (!list.length) { %>
  <p>No orders yet. <a href="/products">Start shopping</a></p>
<% } else { %>
  <table>
    <thead><tr><th>#</th><th>Status</th><th>Coupon</th><th>Total</th><th>Date</th><th></th></tr></thead>
    <tbody>
      <% list.forEach(o => { %>
        <tr>
          <td>#<%= o.id %></td>
          <td><%= o.status %></td>
          <td><%= o.coupon || '-' %></td>
          <td>$<%= (o.total_cents / 100).toFixed(2) %></td>
          <td><%= o.created_at %></td>
          <td><a href="/orders/<%= o.id %>">view</a></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>
<%- include('partials/footer') %>

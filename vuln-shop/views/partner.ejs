<%- include('partials/header') %>
<h1>Partner portal</h1>
<p class="hint">B2B wholesale partners sign in here. The portal speaks JSON
(<code>Content-Type: application/json</code>).</p>

<h2>Sign in</h2>
<form id="partner-login">
  <label>Username <input type="text" name="username" autocomplete="off"></label>
  <label>Password <input type="password" name="password" autocomplete="off"></label>
  <button type="submit">Sign in</button>
</form>
<pre id="partner-result" class="diag-output" aria-live="polite"></pre>

<h2>API</h2>
<ul>
  <li><code>POST /partner/login</code> &mdash; JSON <code>{ "username": "...", "password": "..." }</code></li>
  <li><code>POST /partner/find</code> &mdash; JSON <code>{ "filter": { ... } }</code></li>
</ul>

<script>
  document.getElementById('partner-login').addEventListener('submit', function (ev) {
    ev.preventDefault();
    var f = ev.target;
    fetch('/partner/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ username: f.username.value, password: f.password.value })
    })
      .then(function (r) { return r.json(); })
      .then(function (j) { document.getElementById('partner-result').textContent = JSON.stringify(j, null, 2); })
      .catch(function (e) { document.getElementById('partner-result').textContent = String(e); });
  });
</script>
<%- include('partials/footer') %>

<%- include('partials/header') %>
<a href="/products" class="back">&larr; back to catalog</a>
<div class="product-page">
  <img src="<%= p.image_url %>" alt="<%= p.name %>" onerror="this.style.display='none'">
  <div class="info">
    <h1><%= p.name %></h1>
    <p class="sku"><%= p.sku %> &middot; <%= p.category %></p>
    <p class="price">$<%= (p.price_cents / 100).toFixed(2) %></p>
    <p><%= p.description %></p>
    <p>In stock: <%= p.stock %></p>
    <form method="post" action="/cart/add">
      <input type="hidden" name="product_id" value="<%= p.id %>">
      <input type="hidden" name="price_cents" value="<%= p.price_cents %>">
      <label>Quantity <input type="number" name="qty" value="1" min="1"></label>
      <button>Add to cart</button>
    </form>
  </div>
</div>

<h2>Reviews</h2>
<% if (msg === 'review_added') { %><p class="ok">Review added.</p><% } %>
<ul class="reviews">
  <% reviews.forEach(r => { %>
    <li>
      <strong><%= r.username || 'guest' %></strong>
      &middot; <%= r.rating %>/5
      <div class="body"><%- r.body %></div>
    </li>
  <% }) %>
</ul>

<% if (user) { %>
  <h3>Leave a review</h3>
  <form method="post" action="/products/<%= p.id %>/reviews">
    <label>Rating <input type="number" name="rating" min="1" max="5" value="5"></label>
    <label>Comment <textarea name="body" rows="3"></textarea></label>
    <button>Post review</button>
  </form>
<% } else { %>
  <p><a href="/login?next=/products/<%= p.id %>">Sign in to leave a review</a></p>
<% } %>
<%- include('partials/footer') %>

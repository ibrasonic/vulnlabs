<%- include('partials/header') %>
<h1>Search results</h1>
<p>Showing matches for &ldquo;<%- q %>&rdquo;</p>
<% if (error) { %><pre class="error"><%= error %></pre><% } %>
<form method="get" action="/products/search" class="refine">
  <label>Refine
    <input type="text" name="q" value="<%- qAttr %>">
  </label>
  <% if (typeof safe !== 'undefined' && safe) { %><input type="hidden" name="safe" value="1"><% } %>
  <button>Search again</button>
</form>
<!-- VULN: reflected XSS in an UNQUOTED attribute. qAttr encodes < and > but
     not spaces or quotes, and the value lands in an unquoted attribute, so a
     space alone starts a new attribute: q=x onmouseover=alert(1) -->
<p class="recent-q" data-q=<%- qAttr %>>Recent search remembered.</p>
<div class="catalog">
  <% rows.forEach(p => { %>
    <div class="product-card">
      <a href="/products/<%= p.id %>"><h3><%= p.name %></h3>
      <p class="sku"><%= p.sku %></p>
      <p class="price">$<%= ((p.price_cents || 0) / 100).toFixed(2) %></p></a>
    </div>
  <% }) %>
</div>
<%- include('partials/footer') %>

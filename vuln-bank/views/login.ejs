<%- include('partials/header') %>
<section class="auth-card">
  <h1>Sign in</h1>
  <p class="muted">Access your accounts, transfers and statements.</p>
  <% if (error) { %><p class="err"><%- error %></p><% } %>
  <form method="post" action="/login" class="stacked">
    <label>Username <input name="username" autofocus required></label>
    <label>Password <input name="password" type="password" required></label>
    <input type="hidden" name="next" value="<%= next %>">
    <button>Sign in</button>
  </form>
  <p class="auth-links"><a href="/register">Open an account</a> &middot; <a href="/forgot">Forgot password?</a> &middot; <a href="/login/code">Sign in with a login code</a></p>
</section>
<script>
  // VULN: `next` reflected into a JavaScript string literal with only the
  // `"` character escaped. The `\` character is NOT escaped, so a payload
  // ending in `\"` slips past the half-baked escape and the next `";`
  // opens a fresh JavaScript statement.
  var lastNext = "<%- (typeof next === 'string' ? next : '').replace(/"/g, '\\"') %>";
  if (lastNext && lastNext !== '/accounts') { console.log('[bank] next =', lastNext); }
</script>
<%- include('partials/footer') %>

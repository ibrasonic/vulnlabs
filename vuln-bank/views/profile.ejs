<%- include('partials/header') %>
<h1>Profile</h1>
<% if (msg) { %><p class="ok"><%- msg %></p><% } %>
<% if (error) { %><p class="err"><%- error %></p><% } %>
<form method="post" action="/profile">
  <label>Full name <input name="full_name" value="<%- u.full_name %>"></label>
  <label>Phone <input name="phone" value="<%- u.phone || '' %>"></label>
  <label>Address <input name="address" value="<%- u.address || '' %>"></label>
  <label>Settings (JSON)
    <textarea name="settings" rows="6"><%- u.profile_json %></textarea>
  </label>
  <button>Save</button>
</form>

<h2>Your NovaTrust API profile</h2>
<p class="muted">The bank app is API-backed. This panel loads over the NovaTrust mobile
API (<code>GET /api/me</code>) using a token minted from your session, and saves your
contact details back through it (<code>PUT /api/users/&lt;you&gt;</code>).</p>
<div class="ticket">
  <p id="api-status" class="muted">Loading your API profile&hellip;</p>
  <form id="api-contact" hidden>
    <label>Full name <input id="api-fullname"></label>
    <label>Phone <input id="api-phone"></label>
    <button type="submit">Update contact details</button>
    <span id="api-saved" class="ok"></span>
  </form>
</div>
<script>
(function () {
  var me = null, token = null;
  async function apiToken() {
    if (token) return token;
    token = (await (await fetch('/api/token')).json()).token;
    return token;
  }
  async function load() {
    try {
      var t = await apiToken();
      me = await (await fetch('/api/me', { headers: { Authorization: 'Bearer ' + t } })).json();
      document.getElementById('api-status').textContent =
        'Signed in to the NovaTrust API as ' + me.username + ' (id ' + me.id + ').';
      document.getElementById('api-fullname').value = me.full_name || '';
      document.getElementById('api-phone').value = me.phone || '';
      document.getElementById('api-contact').hidden = false;
    } catch (e) {
      document.getElementById('api-status').textContent = 'Could not reach the NovaTrust API.';
    }
  }
  document.getElementById('api-contact').addEventListener('submit', async function (ev) {
    ev.preventDefault();
    var t = await apiToken();
    // The app sends only the two fields the form edits.
    var body = {
      full_name: document.getElementById('api-fullname').value,
      phone: document.getElementById('api-phone').value
    };
    var r = await fetch('/api/users/' + me.id, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + t },
      body: JSON.stringify(body)
    });
    document.getElementById('api-saved').textContent = r.ok ? 'saved' : 'error';
  });
  load();
})();
</script>

<h2>Connected apps &amp; API access</h2>
<p class="muted">Review the third-party apps connected to your account and your
personal API access token.</p>
<p><a class="btn ghost" href="/connected">Manage connected apps &amp; API access &raquo;</a></p>

<h2>Security check</h2>
<p class="muted">Some sensitive actions ask you to confirm a one-time code we text
you.</p>
<p><a class="btn ghost" href="/security/verify">Verify your identity &raquo;</a></p>

<h2>Bank webhook</h2>
<p>Have us notify your service when a transfer settles.</p>
<form method="post" action="/webhooks">
  <label>Notify URL <input name="url" placeholder="https://your-service.example.com/notify"></label>
  <label>Event
    <select name="event">
      <option>transfer.completed</option>
      <option>statement.uploaded</option>
    </select>
  </label>
  <button>Register</button>
</form>

<h2>Account flags</h2>
<button onclick="checkFlags()">Check entitlements</button>
<pre id="flags"></pre>
<script>
async function checkFlags() {
  const r = await fetch('/profile/admin-check', { credentials: 'include' });
  document.getElementById('flags').textContent = await r.text();
}
</script>
<%- include('partials/footer') %>

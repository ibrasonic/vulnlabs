<%- include('partials/header') %>
<h1>Account <%= acct.account_number %></h1>
<p>Holder: <strong><%- owner.full_name %></strong> (<%- owner.username %>)</p>
<p>Type: <%= acct.account_type %> &middot; Balance: <strong>$<%= (acct.balance_cents / 100).toFixed(2) %></strong></p>
<h2>Recent activity</h2>
<table>
  <thead><tr><th>Date</th><th>From</th><th>To</th><th>Amount</th><th>Memo</th></tr></thead>
  <tbody>
  <% for (const t of tx) { %>
    <tr>
      <td><%= t.created_at %></td>
      <td><%= t.from_account %></td>
      <td><%= t.to_account %></td>
      <td>$<%= (t.amount_cents / 100).toFixed(2) %></td>
      <td><%- t.memo %></td>
    </tr>
  <% } %>
  </tbody>
</table>
<p><a href="/accounts">&laquo; All accounts</a></p>
<%- include('partials/footer') %>

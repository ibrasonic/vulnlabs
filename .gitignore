# ---------------------------------------------------------------------------
# vulnlabs .gitignore
# Keep source + docs. Ignore secrets, runtime data, and per-machine output.
# ---------------------------------------------------------------------------

# --- Secrets (NEVER commit) -----------------------------------------------
.env
**/.env
*.pem
*.key
*.crt
*.p12
*.pfx

# --- curl cookie jars (contain live session tokens) -----------------------
*.jar
!**/lib/*.jar
!**/jars/*.jar

# --- Per-app runtime data (regenerated by seed.js) -------------------------
**/data/*.db
**/data/*.db-shm
**/data/*.db-wal
**/data/uploads/*
!**/data/uploads/.gitkeep
**/data/plugins/
**/data/.deserialize-flag
**/data/access.log
**/data/moderation.log

# --- Node / npm ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/

# --- Python (email-service venv + caches) ----------------------------------
**/.venv/
**/__pycache__/
*.pyc
*.pyo
.pytest_cache/

# --- Test / smoke output ---------------------------------------------------
smoke-out.txt
smoke-test.log
.docker-*.log
*.log

# --- OS / IDE noise --------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~

# --- Build artefacts -------------------------------------------------------
dist/
build/
coverage/
